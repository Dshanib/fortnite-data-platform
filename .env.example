# Copy to .env and fill in values. Never commit .env.

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_SHOP=fortnite.raw.shop
KAFKA_TOPIC_COSMETICS=fortnite.raw.cosmetics
KAFKA_TOPIC_ISLANDS=fortnite.raw.islands
KAFKA_TOPIC_ISLAND_METRICS=fortnite.raw.island_metrics
KAFKA_TOPIC_INGESTION_STATUS=fortnite.ops.ingestion_status

# MinIO (app + docker compose — set your own local values)
MINIO_PROFILE=internal
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=fortnite-data
MINIO_SECURE=false

# Telegram
TELEGRAM_BOT_TOKEN=

# DuckDB serving layer (queries Gold Parquet; not the storage layer)
DUCKDB_PATH=data/serving.duckdb
# direct_minio = read Gold from MinIO via httpfs; local_cache = sync to GOLD_DATA_ROOT
DUCKDB_GOLD_READ_MODE=direct_minio
# Local cache of Gold Parquet (sync from MinIO via scripts/check_duckdb_serving.py)
GOLD_DATA_ROOT=data/gold
# Optional per-dataset overrides (directory or glob):
# GOLD_CURRENT_ISLAND_ACTIVITY_PATH=data/gold/current_island_activity
# GOLD_TOP_ISLANDS_BY_PEAK_CCU_PATH=data/gold/top_islands_by_peak_ccu
# GOLD_ISLAND_METRIC_HOURLY_PATH=data/gold/island_metric_hourly
# GOLD_ISLAND_ACTIVITY_ANOMALIES_PATH=data/gold/island_activity_anomalies
# GOLD_SHOP_RARITY_DISTRIBUTION_PATH=data/gold/shop_rarity_distribution
# GOLD_SOURCE_HEALTH_SUMMARY_PATH=data/gold/source_health_summary

# Source 1: Fortnite-API.com — shop & cosmetics reference data
# https://fortnite-api.com
FORTNITE_API_BASE_URL=https://fortnite-api.com
FORTNITE_API_KEY=
# Max cosmetics records per Kafka message (avoids broker size limits)
FORTNITE_COSMETICS_KAFKA_CHUNK_SIZE=400
# Optional cap for gold/top_islands_by_peak_ccu (empty = all islands)
FORTNITE_GOLD_TOP_ISLANDS_N=

# Source 2: Fortnite Ecosystem API — island engagement metrics
# https://api.fortnite.com/ecosystem/v1/docs/
FORTNITE_ECOSYSTEM_API_BASE_URL=https://api.fortnite.com/ecosystem/v1
FORTNITE_CLIENT_ID=
FORTNITE_CLIENT_SECRET=
FORTNITE_ECOSYSTEM_METRIC_INTERVAL=minute
FORTNITE_ECOSYSTEM_ISLAND_PAGE_SIZE=100
FORTNITE_ECOSYSTEM_DEMO_ISLAND_CODE=
FORTNITE_ECOSYSTEM_DEFAULT_METRICS=peakCCU,uniquePlayers,plays,minutesPlayed

# Airflow (Docker Compose — docker compose --profile airflow up -d)
# Generate once, keep only in .env (never commit real values):
#   python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
AIRFLOW_FERNET_KEY=
AIRFLOW_UID=0
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin
FORTNITE_MAX_ISLANDS=50
FORTNITE_SERVING_MODE=direct_minio
FORTNITE_MAX_MESSAGES_PER_TOPIC=20

# Logging / HTTP
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=30
REQUEST_RETRY_COUNT=3
